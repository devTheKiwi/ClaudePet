{
  "name": "claudepet",
  "version": "2.6.0",
  "description": "Taskbar 위를 돌아다니는 Claude Code 데스크탑 펫 (Windows)",
  "main": "dist/main/main.js",
  "scripts": {
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "tsc -p tsconfig.renderer.json",
    "build:html": "node scripts/copy-html.js",
    "build:icon": "node scripts/build-icon.js",
    "build": "npm run build:main && npm run build:renderer && npm run build:html && npm run build:icon",
    "start": "npm run build && electron .",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder"
  },
  "author": "devTheKiwi",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.10.0",
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3",
    "typescript": "^5.4.0"
  },
  "build": {
    "appId": "com.claudepet.app",
    "productName": "ClaudePet",
    "directories": {
      "output": "release",
      "buildResources": "assets"
    },
    "files": [
      "dist/**/*",
      "src/renderer/**/*.html",
      "assets/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "ClaudePet"
    }
  }
}
